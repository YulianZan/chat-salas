# Base de datos
POSTGRES_PASSWORD=reservas_dev_password

# URLs públicas (sin barra final)
PUBLIC_URL=https://reservas-tu-dominio.example.com
FRONTEND_URL=https://reservas-tu-dominio.example.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=pega_aqui_el_token_del_tunel

# OAuth Office 365 / Azure AD
# Registrar app en https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI a configurar en Azure: ${PUBLIC_URL}/auth/callback
AZURE_CLIENT_ID=client_id_del_app_en_azure
AZURE_CLIENT_SECRET=client_secret_del_app_en_azure
AZURE_TENANT_ID=tenant_id_de_tu_organizacion

# Secreto para firmar cookies de sesión (genera uno random: openssl rand -hex 32)
SESSION_SECRET=cambia_esto_por_un_secreto_seguro

# Teams Bot (opcional)
MicrosoftAppId=app_id_del_bot_en_azure
MicrosoftAppPassword=client_secret_del_bot_en_azure
DEFAULT_EMAIL_DOMAIN=empresa.cl
